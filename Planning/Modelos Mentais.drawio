        <mxCell id="311" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Modelo Simples de Memória&lt;/h1&gt;&lt;p&gt;Cada situação vai estar ligada à seu respectivo Objetivo, esse objetivo PODE incluir TUDO o que é necessário para sua realização (Esperanças podem estar inclusas e satisfazer).&lt;/p&gt;&lt;p&gt;Alguns proessos mentais podem estar entre ou em paralelo à esse modelo (como por exemplo, confirmar a situação e atualizar o objetivo)&amp;nbsp;&lt;/p&gt;" vertex="1">
          <mxGeometry height="330" width="290" x="690" y="1870" as="geometry" />
        </mxCell>
