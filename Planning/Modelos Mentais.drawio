        <mxCell id="429" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;imageWidth=20;resizeWidth=1;" value="&lt;ul&gt;Córtex Pré Frontal (Previsor de Resultados Ponderados - Juízo)&lt;/ul&gt;&lt;ul&gt;&lt;br&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;Novidade: Você está aprendendo uma habilidade nova (ex: dirigir pela primeira vez).&lt;/li&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;Complexidade: Quando o problema exige raciocínio, lógica ou cálculos.&lt;/li&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;Conflito e Decisão: Quando você precisa escolher entre duas opções ou resistir a um impulso (ex: não comer o doce porque está de dieta) [2].&lt;/li&gt;&lt;li style=&quot;text-align: justify;&quot;&gt;Foco Atencioso: Quando você decide ignorar distrações para se concentrar em algo específico&amp;nbsp;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="160" width="820" x="5320" y="1920" as="geometry" />
        </mxCell>
        <mxCell id="441" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="As memórias complexas e dados registrados de muito tempo, são mais lentos de recuperar. (Córtex)&lt;div&gt;&lt;div&gt;Por outro lado, o Aperfeiçoador de Ações (Cerebelo), é feito pra agir e decidir mais rápido (e gerenciar Desejo vs Realidade&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="40" width="680" x="5371.87" y="2160" as="geometry" />
        </mxCell>
        <mxCell id="447" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="SIM, existem sensores ESPECIFICAMENTE POSICIONADOS para perceber estímulos de DOR (Nocireceptores)" vertex="1">
          <mxGeometry height="30" width="630" x="5376.87" y="2290" as="geometry" />
        </mxCell>
        <mxCell id="448" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="Conceito: Bottom-Up e Top-Down (psico, neuro e comput.)" vertex="1">
          <mxGeometry height="30" width="330" x="5386.87" y="2388" as="geometry" />
        </mxCell>
        <mxCell id="459" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="Fatos aleatórios:&lt;div&gt;- &quot;Olfato&quot; pode ir direto para o Córtex (e depois pro tálamo)... Vai entender.. Mas pode ser útil saber que existe canal direto fora do Tálamo (E é só essa exceção que conheço até agora)&lt;/div&gt;" vertex="1">
