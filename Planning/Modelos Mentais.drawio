        <mxCell id="315" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="PASSO À PASSO&amp;nbsp;&lt;div&gt;DE VISUALIZAÇÃO&amp;nbsp;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;DE NECESSIDADE&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;&amp;nbsp;para construir IA&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="240" x="200" y="2612.5" as="geometry" />
        </mxCell>
        <mxCell id="318" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="(&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;Descrever Quais)&lt;/span&gt;" vertex="1">
